# Environment variables for Snowflake Postgres connection
# Copy this file to .env and fill in your values

# Postgres connection (from CREATE POSTGRES INSTANCE output)
PG_HOST=your-instance-id.sfsenorthamerica-yourorg.us-east-1.aws.postgres.snowflake.app
PG_PORT=5432
PG_DATABASE=ecommerce
PG_USER=app_user
PG_PASSWORD=your-password-here

# Server port
PORT=3001
